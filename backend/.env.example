# ──────────────────────────────────────────
# FIAE AP2 Trainer — Backend Konfiguration
# Kopiere diese Datei als .env und fülle sie aus
# ──────────────────────────────────────────

# Google Gemini API Key (kostenloser Tier: 1.500 req/Tag)
# Erstellen unter: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=dein_gemini_api_key_hier

# Server-Port
PORT=8031

# Frontend-URL für CORS (Entwicklung)
FRONTEND_URL=http://localhost:8030
