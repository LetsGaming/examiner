# ──────────────────────────────────────────
# FIAE AP2 Trainer — Backend Konfiguration
# Kopiere diese Datei als .env und fülle sie aus
# ──────────────────────────────────────────

# OpenAI API Key
# Erstellen unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=dein_openai_api_key_hier

# Server-Port (Production: 8031)
PORT=8031

# Erlaubte Frontend-Origins für CORS (kommasepariert)
# Lokal: http://localhost:8030 wird automatisch erlaubt
# Production: deine öffentliche Domain hier eintragen
FRONTEND_URLS=https://examiner.letsgaming.de,http://localhost:8030
