{
  "name": "fiae-ap2-trainer-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@ionic/vue": "^8.8.7",
    "@ionic/vue-router": "^8.8.7",
    "axios": "^1.16.1",
    "ionicons": "^8.0.13",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "prettier": "^3.8.3",
    "@vue/eslint-config-prettier": "^10.2.0"
  }
}
