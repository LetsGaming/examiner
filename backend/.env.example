# ──────────────────────────────────────────
# FIAE AP2 Trainer — Backend Konfiguration
# Kopiere diese Datei als .env und fülle sie aus
# ──────────────────────────────────────────

# OpenAI API Key (kostenloser Tier: 1.500 req/Tag)
# Erstellen unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=dein_openai_api_key_hier

# Server-Port
PORT=8031

# Frontend-URL für CORS (Entwicklung)
FRONTEND_URL=http://localhost:8030
