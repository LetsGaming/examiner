# ──────────────────────────────────────────────────────────────────────────────
# FIAE AP2 Trainer — Backend Konfiguration
# Kopiere diese Datei als .env und fülle sie aus
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentifizierung ─────────────────────────────────────────────────────────
# Geheimnis für JWT-Signierung (min. 32 Zeichen zufälliger String).
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WICHTIG: Bei Änderung werden alle aktiven Sessions ungültig!
JWT_SECRET=ersetze_mit_zufaelligem_64_zeichen_hex

# ── KI-Anbieter ───────────────────────────────────────────────────────────────
# Nur EINEN Key setzen — der erste konfigurierte wird als Server-Fallback genutzt.
# User-Keys (über die Einstellungen im Frontend gesetzt) haben immer Vorrang.
#
# OpenAI:     https://platform.openai.com/api-keys
# Anthropic:  https://console.anthropic.com/settings/keys
# Google:     https://aistudio.google.com/apikey
# Mistral:    https://console.mistral.ai/api-keys

OPENAI_API_KEY=dein_openai_api_key_hier
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# MISTRAL_API_KEY=...

# ── Verschlüsselung ───────────────────────────────────────────────────────────
# Geheimnis für AES-256-GCM-Verschlüsselung gespeicherter User-API-Keys.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WICHTIG: Bei Änderung werden alle gespeicherten User-Keys ungültig!
API_KEY_SECRET=ersetze_mit_zufaelligem_64_zeichen_hex

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8031

# Erlaubte Frontend-Origins für CORS (kommasepariert)
FRONTEND_URLS=https://examiner.letsgaming.de,http://localhost:8030
